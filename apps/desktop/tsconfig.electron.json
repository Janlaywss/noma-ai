{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "electron"],
    "rootDir": "src",
    "outDir": "dist-electron",
    "noEmit": false,
    "incremental": false,
    "declaration": false,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/main.ts", "src/main/**/*.ts", "src/preload.cts"]
}
