# Hono server env. Copy to .env — loaded via tsx --env-file=.env.

PORT=3677

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key

# ── LLM ───────────────────────────────────────────────────
# OpenRouter routes to Claude, GPT, Gemini, etc.
OPENROUTER_API_KEY=

# Main agent model (conversational task creation via Codex CLI)
NOMA_AGENT_MODEL=anthropic/claude-sonnet-4-20250514

# Event evaluation model (lightweight LLM call for connector events)
NOMA_EVENT_MODEL=anthropic/claude-sonnet-4-20250514

# ── Google OAuth (for Gmail connector) ────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Public URL (ngrok tunnel for OAuth callbacks) ─────────
# The server auto-starts an ngrok tunnel using this domain.
PUBLIC_URL=https://your-app.ngrok-free.dev
