{
  "name": "@noma/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @noma/shared build && pnpm --filter @noma/event-agent build && tsx watch --env-file=.env src/index.ts",
    "start": "pnpm --filter @noma/shared build && pnpm --filter @noma/event-agent build && tsx --env-file=.env src/index.ts",
    "eval:agent": "pnpm --filter @noma/eval eval:agent",
    "build": "pnpm --filter @noma/shared build && pnpm --filter @noma/event-agent build && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@hono/node-server": "^2.0.0",
    "@mozilla/readability": "^0.6.0",
    "@noma/event-agent": "workspace:*",
    "@noma/shared": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@supabase/supabase-js": "^2.104.0",
    "ai": "^6.0.168",
    "cron-parser": "^5.5.0",
    "hono": "^4.12.0",
    "linkedom": "^0.18.12",
    "redis": "^5.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
