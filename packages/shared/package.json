{
  "name": "@noma/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./chat/stream-types": {
      "types": "./dist/chat/stream-types.d.ts",
      "import": "./dist/chat/stream-types.js"
    },
    "./chat/adapter": {
      "types": "./dist/chat/adapter.d.ts",
      "import": "./dist/chat/adapter.js"
    },
    "./supabase/types": {
      "types": "./dist/supabase/types.d.ts",
      "import": "./dist/supabase/types.js"
    },
    "./agent/models": {
      "types": "./dist/agent/models.d.ts",
      "import": "./dist/agent/models.js"
    },
    "./agent/tool-schemas": "./src/agent/tool-schemas.json",
    "./agent/tool-schemas.json": "./src/agent/tool-schemas.json",
    "./agent/builtin-connectors": {
      "types": "./dist/agent/builtin-connectors.d.ts",
      "import": "./dist/agent/builtin-connectors.js"
    },
    "./agent/builtin-connectors.json": "./src/agent/builtin-connectors.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
